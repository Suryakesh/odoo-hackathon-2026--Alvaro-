          <field name="x_studio_driver"/>
          <field name="x_studio_cargo_weight"/>
          <field name="x_studio_planned_distance"/>
          <field name="x_studio_final_odometer_1"/>
          <field name="x_studio_fuel_consumed"/>
        </xpath>
