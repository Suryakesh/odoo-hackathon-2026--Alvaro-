  <record id="default_kanban_view__c18d5cbe-547f-4db2-aa15-f2928e7e4ca9" model="ir.ui.view" context="{'studio': True}">
    <field name="arch" type="xml">
      <kanban default_group_by="x_studio_stage_id" highlight_color="x_color">
        <field name="x_color"/>
        <progressbar field="x_studio_kanban_state" colors="{&quot;normal&quot;: &quot;200&quot;, &quot;done&quot;: &quot;success&quot;, &quot;blocked&quot;: &quot;danger&quot;}"/>
        <templates>
          <t t-name="menu">
            <a t-if="widget.editable" role="menuitem" type="open" class="dropdown-item">Edit</a>
            <a t-if="widget.deletable" role="menuitem" type="delete" class="dropdown-item">Delete</a>
            <field widget="kanban_color_picker" name="x_color"/>
          </t>
          <t t-name="card" class="flex-row">
            <main>
              <div name="studio_auto_kanban_header" class="d-flex">
                <field name="x_studio_priority" widget="boolean_favorite" nolabel="1"/>
                <field name="display_name" class="h5"/>
                <field name="x_studio_sequence" widget="handle" invisible="1"/>
              </div>
              <div name="studio_auto_kanban_body"/>
              <footer>
                <div class="ms-auto d-flex align-items-center">
                  <field name="x_studio_kanban_state" widget="state_selection"/>
                </div>
              </footer>
            </main>
          </t>
        </templates>
      </kanban>
    </field>
    <field name="key">studio_customization.default_kanban_view__c18d5cbe-547f-4db2-aa15-f2928e7e4ca9</field>
    <field name="model">x_trip</field>
    <field name="name">Default kanban view for x_trip</field>
    <field name="type">kanban</field>
  </record>
