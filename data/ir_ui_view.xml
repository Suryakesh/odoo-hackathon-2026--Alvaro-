  <record id="odoo_studio_default__6e0fc046-6380-4033-a46f-6ae689134841" model="ir.ui.view" context="{'studio': True}">
    <field name="arch" type="xml">
      <data>
        <xpath expr="/form//field[@name='x_studio_stage_id']" position="attributes">
