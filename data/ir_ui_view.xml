    <field name="inherit_id" ref="default_form_view_fo_9433215e-bb5b-4bc9-b8fc-3fde24084cf7"/>
    <field name="key">studio_customization.odoo_studio_default__6e0fc046-6380-4033-a46f-6ae689134841</field>
    <field name="mode">extension</field>
    <field name="model">x_trip</field>
    <field name="name">Odoo Studio: Default form view for x_trip customization</field>
    <field name="priority">99</field>
    <field name="type">form</field>
  </record>
