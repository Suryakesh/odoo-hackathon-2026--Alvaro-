# ──────────────────────────────────────────────────────────────────────────
# TransitOps — Odoo API Configuration
# ──────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored, so your credentials stay safe.
#
# Two authentication modes:
#   Option A (recommended): API Key — set ODOO_API_KEY
#   Option B: Session auth — set ODOO_LOGIN + ODOO_PASSWORD
# ──────────────────────────────────────────────────────────────────────────

# Your Odoo instance URL (no trailing slash)
ODOO_URL=https://alvaro33.odoo.com

# Database name (check Settings → Database Name in Odoo)
ODOO_DB=alvaro33

# ── Option A: API Key auth (preferred) ──────────────────────────────────
# Generate at: Profile → Account Security → API Keys → New API Key
ODOO_API_KEY=

# ── Option B: Session auth (fallback) ──────────────────────────────────
# ODOO_LOGIN=your-email@example.com
# ODOO_PASSWORD=your-password
